    "reject_symlink_components": true,
    "outer_target_images_authorized": false,
    "outer_target_labels_authorized": false,
    "outer_target_images_used": false,
    "outer_target_labels_used": false
  },
  "score_protocol": {
    "primary_representation": "float32_raw_logit",
    "prediction_rule": "float32_raw_logit >= shared_threshold_logit",
    "exact_state_enumeration_is_primary": true,
    "shared_threshold_across_source_domains": true,
    "dense_grid_is_diagnostic_only": true,
    "probability_threshold_sweep_allowed": false,
    "inference_autocast_enabled": false,
    "matching": {
      "matching_rule": "overlap",
      "centroid_distance": 3.0,
      "connectivity": 2,
      "min_component_area": 1
    },
    "budgets": [
      {"name": "strict", "pixel": 0.000001, "component": 1.0},
      {"name": "medium", "pixel": 0.000005, "component": 5.0},
      {"name": "loose", "pixel": 0.00001, "component": 10.0}
    ]
  },
  "decision_protocol": {
    "sequential_gates": [
      {"name": "contrast_vs_control", "candidate": "c", "baseline": "control"},
      {"name": "component_context_vs_contrast", "candidate": "cv", "baseline": "c"}
    ],
    "paired_seed_aggregation": "arithmetic_mean_of_candidate_minus_baseline_per_seed",
    "strict_macro_mean_min_delta": 0.005,
    "strict_macro_positive_seed_consensus_min": 2,
    "other_mean_min_delta": 0.0,
    "worst_seed_min_delta": -0.005,
    "numeric_atol": 1e-12,
    "missing_or_infeasible_point": "TIER2R_HOLD",
    "non_finite_metric": "TIER2R_HOLD",
    "selection_table": {
      "A_GO_B_GO": "select_cv_and_retain_component_claim",
      "A_GO_B_HOLD": "select_c_and_drop_component_claim",
      "A_HOLD": "overall_hold"
    },
    "all_nine_criteria_and_worst_seed_checks_must_pass": true
  },
  "training_protocol": {
    "checkpoint_selection": "fixed_last",
    "checkpoint_epoch_zero_based": 79,
    "matched_initializer_within_seed_fold": true,
    "matched_initial_extension_state_within_seed_fold": true,
    "physical_gpus": [2, 3],
    "physical_gpu_assignment": "preregistered_exact_per_job",
    "schedule_order": "seed_local_interleaved_and_role_gpu_counterbalanced",
    "wait_for_idle_gpu": false,
    "allow_gpu_fallback": false,
    "total_detector_jobs": 18
  },
  "authorization_protocol": {
    "source_tier3_design_authorization_is_separate": true,
    "outer_target_access_authorization_is_separate": true,
